{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --legacy-peer-deps && npm run build"
  },
  "deploy": {
    "startCommand": "sh -c \"npx serve -s dist -l tcp://0.0.0.0:$PORT\"",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
